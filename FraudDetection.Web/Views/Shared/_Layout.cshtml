@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string NavActive(string controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    bool isAdmin = User.IsAdmin();
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · TravaPix</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="app-shell" id="appShell">
        <aside class="sidebar" id="sidebar">
            <a class="brand" href="@Url.Action("Index", "Dashboard")">
                <span class="brand-shield">
                    <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        <path d="M9 12l2 2 4-4" />
                    </svg>
                </span>
                <span class="brand-name">Trava<strong>Pix</strong></span>
            </a>

            <nav class="nav">
                <a class="nav-item @NavActive("Dashboard")" href="@Url.Action("Index", "Dashboard")">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
                    <span>Dashboard</span>
                </a>
                <a class="nav-item @NavActive("Transaction")" href="@Url.Action("Create", "Transaction")">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                    <span>Nova Transação</span>
                </a>
                <a class="nav-item @NavActive("History")" href="@Url.Action("Index", "History")">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v5h5"/><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/><path d="M12 7v5l4 2"/></svg>
                    <span>Histórico</span>
                </a>
                @if (isAdmin)
                {
                    <a class="nav-item @NavActive("Fraud")" href="@Url.Action("Index", "Fraud")">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        <span>Fraudes</span>
                    </a>
                }
            </nav>

            <form class="logout-form" asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-item logout">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    <span>Sair</span>
                </button>
            </form>
        </aside>

        <div class="backdrop" id="backdrop"></div>

        <div class="main">
            <header class="topbar">
                <button class="menu-toggle" id="menuToggle" aria-label="Abrir menu">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="topbar-right">
                    <span class="secure-badge">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        Sistema Seguro
                    </span>
                    <span class="user-chip">@User.GetFirstName()</span>
                </div>
            </header>

            <main class="content">
                @if (TempData["Success"] is string success)
                {
                    <div class="alert alert-success">@success</div>
                }
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

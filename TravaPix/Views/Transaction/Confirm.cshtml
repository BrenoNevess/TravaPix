@model TransactionConfirmViewModel
@{
    ViewData["Title"] = "Revisar transação";
}

@section Styles {
    <link rel="stylesheet" href="~/css/transaction.css" asp-append-version="true" />
}

<div class="tx-single">
    <div class="panel">
        <div class="panel-head">
            <h3>Confirme os dados da transação</h3>
            <span class="badge @Model.RiskLevel.ToBadgeClass()">@Model.RiskLevel.ToPortuguese()</span>
        </div>

        <div class="review-amount">
            <span>Os dados abaixo estão corretos?</span>
            <strong>R$ @Model.Amount.ToString("N2")</strong>
        </div>

        <ul class="review-meta">
            <li><span>Remetente</span><strong>@Model.SenderCpf</strong></li>
            <li><span>Destinatário</span><strong>@Model.ReceiverCpf</strong></li>
            <li><span>Local</span><strong>@(string.IsNullOrWhiteSpace(Model.Location) ? "—" : Model.Location)</strong></li>
            <li><span>Descrição</span><strong>@(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)</strong></li>
        </ul>

        @if (Model.Decision == FraudDecision.Block)
        {
            <div class="callout callout-danger">
                <strong>Atenção: esta transação será bloqueada.</strong>
                <p>@Model.BlockReason</p>
                <p class="callout-note">Para sua segurança, caso prossiga esta transação, o destinatário ficará bloqueado por 8 horas. Se algum dado estiver incorreto, volte e corrija antes de prosseguir.</p>
            </div>
        }
        else if (Model.Decision == FraudDecision.RequireConfirmation)
        {
            <div class="callout callout-warning">
                <strong>Transação suspeita</strong>
                <ul>
                    @foreach (string alert in Model.Alerts)
                    {
                        <li>@alert</li>
                    }
                </ul>
            </div>
        }
        else
        {
            <div class="callout callout-safe">
                <strong>Transação dentro do padrão esperado.</strong>
            </div>
        }

        <form asp-controller="Transaction" asp-action="Confirm" method="post" novalidate>
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="SenderCpf" />
            <input type="hidden" asp-for="ReceiverCpf" />
            <input type="hidden" asp-for="Amount" />
            <input type="hidden" asp-for="Location" />
            <input type="hidden" asp-for="Description" />

            @if (Model.Decision == FraudDecision.RequireConfirmation)
            {
                <div class="signature-box">
                    <h4>Assinatura digital</h4>
                    <p>Para autorizar esta transação suspeita, assine com o seu <strong>nome completo</strong> (exatamente como no cadastro) e confirme a ciência do risco.</p>

                    <div class="field">
                        <label asp-for="SignatureName"></label>
                        <input asp-for="SignatureName" class="input" placeholder="Seu nome completo" />
                        <span asp-validation-for="SignatureName" class="field-error"></span>
                    </div>

                    <label class="check">
                        <input asp-for="AcknowledgedRisk" type="checkbox" />
                        <span>Estou ciente do risco e autorizo esta transação.</span>
                    </label>
                    <span asp-validation-for="AcknowledgedRisk" class="field-error"></span>
                </div>
            }

            <div class="review-actions">
                <a class="btn btn-ghost" href="@Url.Action("Create", "Transaction")">Voltar e corrigir</a>
                @if (Model.Decision == FraudDecision.Block)
                {
                    <button type="submit" class="btn btn-danger">Confirmar mesmo assim</button>
                }
                else
                {
                    <button type="submit" class="btn btn-primary">Confirmar transação</button>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
